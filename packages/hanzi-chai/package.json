{
  "name": "hanzi-chai",
  "version": "0.4.0",
  "description": "提取自主仓库的汉字拆分/编码核心算法包",
  "type": "module",
  "exports": {
    ".": {
      "node": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "browser": {
        "types": "./dist/main.d.ts",
        "default": "./dist/main.js"
      },
      "default": {
        "types": "./dist/main.d.ts",
        "default": "./dist/main.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node -e \"require('fs').cpSync('src/data', 'dist/data', { recursive: true, force: true })\"",
    "test": "bun test ./spec/*.spec.ts",
    "test:all": "bun test spec",
    "prepublishOnly": "npm run build",
    "postversion": "node -e \"const fs=require('fs');const r=JSON.parse(fs.readFileSync('../../package.json','utf8'));r.version=require('./package.json').version;fs.writeFileSync('../../package.json',JSON.stringify(r,null,2)+'\\n');\""
  },
  "dependencies": {
    "d3-array": "^3.2.4",
    "js-yaml": "^4.1.1",
    "lodash-es": "^4.18.1",
    "pako": "^2.1.0"
  },
  "devDependencies": {
    "@types/d3-array": "^3.2.2",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash-es": "^4.17.12",
    "@types/pako": "^2.0.4",
    "bun-types": "latest",
    "typescript": "^6.0.3"
  }
}
