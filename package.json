{
  "name": "chai",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "description": "汉字自动拆分系统网页版",
  "author": {
    "name": "tansongchen",
    "email": "i@tansongchen.com",
    "url": "https://tansongchen.com"
  },
  "version": "0.4.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/hanzi-chai/hanzi-chai.github.io"
  },
  "license": "GPL-3.0-only",
  "engines": {
    "bun": ">=1.0"
  },
  "scripts": {
    "fetch": "bun scripts/fetch.ts",
    "start": "vite --mode PAGES",
    "dev": "vite --mode PAGES",
    "preview": "vite preview --mode PAGES --outDir dist/pages",
    "version": "tsc && bun run build:BEX && bun run build:PAGES && bun run build:CF",
    "lint": "bunx @biomejs/biome lint ./src",
    "fix": "bunx @biomejs/biome lint --fix --unsafe ./src",
    "format": "bunx @biomejs/biome format --write . && git add .",
    "build:pkg": "bun run --filter hanzi-chai build",
    "build:BEX": "bun run build:pkg && vite build --mode BEX",
    "build:PAGES": "bun run build:pkg && vite build --mode PAGES",
    "build:CF": "bun run build:pkg && vite build --mode CF",
    "build:CLIENT": "bun run build:pkg && vite build --mode CLIENT",
    "build": "bun run fetch && bun run build:CF",
    "publish": "bump --tag --commit --push"
  },
  "dependencies": {
    "@ant-design/charts": "^2.6.7",
    "@ant-design/colors": "^8.0.1",
    "@ant-design/icons": "^6.2.3",
    "@ant-design/pro-components": "^2.8.10",
    "@antv/s2": "^2.7.1",
    "@antv/s2-react": "^2.3.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@xyflow/react": "^12.10.2",
    "ahooks": "^3.9.7",
    "antd": "^5.29.3",
    "axios": "^1.16.1",
    "deep-object-diff": "^1.1.9",
    "hanzi-chai": "*",
    "jotai": "^2.20.0",
    "jotai-family": "^1.0.2",
    "jotai-history": "^0.5.1",
    "jotai-location": "^0.6.2",
    "jotai-minidb": "^0.0.8",
    "jotai-optics": "^0.4.0",
    "js-md5": "^0.8.3",
    "js-yaml": "^4.1.1",
    "libchai": "0.4.0",
    "lodash-es": "^4.18.1",
    "nanoid": "^5.1.11",
    "optics-ts": "^2.4.1",
    "pako": "^2.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router": "^7.15.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@emotion/react": "^11.14.0",
    "@jsdevtools/version-bump-prompt": "^6.1.0",
    "@mdx-js/react": "^3.1.1",
    "@mdx-js/rollup": "^3.1.1",
    "@modyfi/vite-plugin-yaml": "^1.1.1",
    "@swc-jotai/react-refresh": "^0.5.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "@types/d3-array": "^3.2.2",
    "@types/js-md5": "^0.8.0",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash-es": "^4.17.12",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.9.0",
    "@types/pako": "^2.0.4",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react-swc": "^4.3.1",
    "bun-types": "^1.3.14",
    "fs-extra": "^11.3.5",
    "jotai-devtools": "^0.14.0",
    "less": "^4.6.4",
    "pre-commit": "^2.0.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vite-plugin-pages": "^0.33.3",
    "vite-plugin-wasm": "^3.6.0",
    "vite-plugin-wasm-pack": "^0.1.12"
  }
}
